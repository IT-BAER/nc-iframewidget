{
	"name": "iframewidget",
	"version": "0.9.5",
	"description": "iFrame Widget for Nextcloud Dashboard",
	"main": "index.js",
	"scripts": {
		"build": "NODE_ENV=production webpack --progress --config webpack.config.js",
		"dev": "NODE_ENV=development webpack --progress --config webpack.config.js",
		"watch": "NODE_ENV=development webpack --progress --watch --config webpack.config.js",
		"lint": "eslint --ext .js,.vue src",
		"lint:fix": "eslint --ext .js,.vue src --fix",
		"stylelint": "stylelint src/**/*.vue src/**/*.scss src/**/*.css",
		"stylelint:fix": "stylelint src/**/*.vue src/**/*.scss src/**/*.css --fix",
		"version:sync": "node scripts/sync-version.js",
		"version:sync:from-xml": "node scripts/sync-version.js --from-xml",
		"version:show": "node scripts/sync-version.js --show",
		"version:bump": "node scripts/sync-version.js --bump-patch",
		"version:bump:minor": "node scripts/sync-version.js --bump-minor",
		"version:bump:major": "node scripts/sync-version.js --bump-major",
		"prebuild": "node scripts/sync-version.js",
		"predev": "node scripts/sync-version.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/IT-BAER/nc-iframewidget"
	},
	"keywords": [
		"iframe",
		"widget"
	],
	"author": "Bruno Miglar",
	"license": "AGPL-3.0",
	"bugs": {
		"url": "https://github.com/IT-BAER/nc-iframewidget/issues"
	},
	"homepage": "https://github.com/IT-BAER/nc-iframewidget",
	"dependencies": {
		"@nextcloud/axios": "^2.5.2",
		"@nextcloud/dialogs": "^5.3.8",
		"@nextcloud/initial-state": "^2.2.0",
		"@nextcloud/router": "^3.0.1",
		"@nextcloud/vue": "^8.35.2",
		"brace-expansion": ">=2.0.2",
		"form-data": ">=4.0.4",
		"pbkdf2": ">=3.1.3",
		"vue": "^2.7.16"
	},
	"devDependencies": {
		"@nextcloud/eslint-config": "8.4.2",
		"@nextcloud/stylelint-config": "3.2.1",
		"@babel/core": "^7.26.10",
		"@babel/preset-env": "^7.26.9",
		"@nextcloud/babel-config": "^1.2.0",
		"@nextcloud/browserslist-config": "^3.0.1",
		"@nextcloud/webpack-vue-config": "^6.0.1",
		"babel-loader": "^10.0.0",
		"cross-env": "^7.0.3",
		"css-loader": "^7.1.2",
		"eslint": "^8.57.1",
		"form-data": ">=4.0.4",
		"linkifyjs": ">=4.3.2",
		"postcss": ">=8.4.31",
		"style-loader": "^4.0.0",
		"stylelint": "^17.3.0",
		"vue-loader": "^15.10.1",
		"vue-template-compiler": "^2.7.16",
		"webpack": "^5.104.0",
		"webpack-cli": "^6.0.1",
		"brace-expansion": ">=2.0.2",
		"pbkdf2": ">=3.1.3"
	},
	"browserslist": [
		"extends @nextcloud/browserslist-config"
	],
	"overrides": {
		"postcss": ">=8.4.31",
		"axios": "1.13.5",
		"ajv": "8.18.0",
		"eslint": {
			"ajv": "6.12.6"
		},
		"@eslint/eslintrc": {
			"ajv": "6.12.6"
		},
		"qs": "6.15.0",
		"mdast-util-to-hast": "13.2.1",
		"fast-xml-parser": ">=4.5.5",
		"flatted": ">=3.4.2",
		"immutable": ">=5.1.5",
		"minimatch": ">=3.1.5",
		"bn.js": ">=4.12.3",
		"dompurify": ">=3.3.3",
		"node-forge": ">=1.4.0",
		"path-to-regexp": ">=0.1.13",
		"picomatch": ">=2.3.2"
	}
}
